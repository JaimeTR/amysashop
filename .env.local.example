# Ejemplo de variables de entorno para la integración de correo
# API Key de SendGrid (necesaria para enviar emails)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email destino que recibirá los mensajes del formulario
CONTACT_TO_EMAIL=contacto@amysashop.com

# Email remitente que aparecerá en los correos
CONTACT_FROM_EMAIL=no-reply@amysashop.com
